# DefMon Environment Variables
# Copy to .env and fill in your values

# Database
DB_USER=defmon
DB_PASS=changeme_secure_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=defmon

# Auth
JWT_SECRET_KEY=changeme_generate_a_random_64_char_string
JWT_ALGORITHM=HS256

# Threat Intelligence
ABUSEIPDB_KEY=

# SOAR Notifications
WEBHOOK_URL=

# App
DEBUG=false
LOG_LEVEL=INFO
ENABLE_LOCAL_COLLECTOR=false
USE_SEED_LOGS=false
